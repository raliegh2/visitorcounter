{
  "name": "church-visitor-attendance-system",
  "version": "1.0.0-rc.2",
  "private": true,
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "node scripts/start-production.mjs",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:test": "supabase test db",
    "db:types": "supabase gen types typescript --local > types/database.generated.ts",
    "security:audit": "npm audit --audit-level=high",
    "bootstrap:admin": "node scripts/create-bootstrap-admin.mjs",
    "security:source": "node scripts/secret-scan.mjs",
    "verify": "npm run typecheck && npm run lint && npm test && npm run security:source && npm run security:audit && npm run build",
    "deploy:preflight": "node scripts/deployment-preflight.mjs",
    "deploy:supabase": "node scripts/deploy-supabase.mjs",
    "deploy:vercel": "node scripts/deploy-vercel.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "0.12.0",
    "@supabase/supabase-js": "2.108.2",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/node": "26.0.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "10.5.0",
    "eslint-config-next": "16.2.9",
    "supabase": "2.107.0",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "overrides": {
    "postcss": "8.5.10",
    "esbuild": "0.28.1"
  }
}
