{
  "name": "church-visitor-attendance-system",
  "version": "1.0.0-rc.3",
  "private": true,
  "packageManager": "npm@10.9.2",
  "engines": { "node": "22.x" },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "node scripts/start-production.mjs",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:test": "supabase test db",
    "db:types": "supabase gen types typescript --local > types/database.generated.ts",
    "security:source": "node scripts/secret-scan.mjs",
    "security:audit": "npm audit --audit-level=high",
    "verify": "npm run typecheck && npm run lint && npm test && npm run security:source && npm run security:audit && npm run build"
  },
  "dependencies": {
    "@supabase/ssr": "0.12.0",
    "@supabase/supabase-js": "2.108.2",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.61.0",
    "@types/node": "22.15.32",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "eslint": "9.29.0",
    "eslint-config-next": "16.2.9",
    "supabase": "2.107.0",
    "typescript": "5.9.2",
    "vitest": "3.2.6"
  },
  "overrides": { "postcss": "8.5.10", "esbuild": "0.28.1" }
}
