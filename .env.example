# Browser-safe Supabase configuration.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_KEY

# Server-only. Never prefix either value with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVER_ONLY_SERVICE_ROLE_KEY
REAUTH_COOKIE_SECRET=REPLACE_WITH_AT_LEAST_32_RANDOM_BYTES

# Public application URL used for password reset and auth callbacks.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Bootstrap-only values used by scripts/create-bootstrap-admin.mjs.
BOOTSTRAP_ORGANIZATION_ID=00000000-0000-4000-8000-000000000001
BOOTSTRAP_ORGANIZATION_NAME=Community Church
BOOTSTRAP_ADMIN_EMAIL=admin@example.test
BOOTSTRAP_ADMIN_PASSWORD=Replace-With-A-Strong-Temporary-Password
BOOTSTRAP_ADMIN_DISPLAY_NAME=Church Administrator
